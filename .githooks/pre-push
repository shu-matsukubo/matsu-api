#!/bin/sh

echo "フォーマットチェック & 静的解析を実行します..."

# pushされる範囲のPHPファイルを取得
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # 新規ブランチの場合はHEADとの差分
    DIFF_FILES=$(git diff --name-only --diff-filter=ACMRT HEAD -- '*.php')
  else
    DIFF_FILES=$(git diff --name-only --diff-filter=ACMRT "$remote_sha" "$local_sha" -- '*.php')
  fi
done

if [ -z "$DIFF_FILES" ]; then
  echo "対象PHPファイルなし。スキップします。"
  exit 0
fi

# Pintで自動修正
echo ""
echo "Pint: フォーマットを適用中..."
echo "$DIFF_FILES" | xargs -r docker compose exec -T web ./vendor/bin/pint

PINT_EXIT=$?

if [ $PINT_EXIT -ne 0 ]; then
  echo "Pintの実行に失敗しました。コンテナが起動しているか確認してください。"
  exit 1
fi

# Pintが修正を加えたか確認
if ! git diff --quiet; then
  echo ""
  echo "Pintがコードを修正しました。"
  echo "修正内容を確認してからcommit & pushしてください。"
  echo ""
  git diff --stat
  exit 1
fi

echo "フォーマット: OK"

# PHPStan静的解析（差分ファイルのみ）
echo ""
echo "PHPStan: 静的解析を実行中..."
echo "$DIFF_FILES" | xargs docker compose exec -T web ./vendor/bin/phpstan analyse --memory-limit=512M

PHPSTAN_EXIT=$?

if [ $PHPSTAN_EXIT -ne 0 ]; then
  echo ""
  echo "PHPStanのエラーを修正してからpushしてください。"
  exit 1
fi

echo "静的解析: OK"
echo ""
echo "すべてのチェックが通りました！"
exit 0
